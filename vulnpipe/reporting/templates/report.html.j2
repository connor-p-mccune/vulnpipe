<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ tool_name }} report</title>
  <style>
    :root { color-scheme: light dark; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      margin: 0; padding: 0 1.5rem 3rem; color: #1b1b1b; background: #fafafa; line-height: 1.45;
    }
    header { padding: 1.5rem 0 1rem; border-bottom: 2px solid #e0e0e0; margin-bottom: 1.5rem; }
    h1 { margin: 0 0 .25rem; font-size: 1.6rem; }
    h2 { font-size: 1.2rem; margin: 2rem 0 .75rem; }
    h3 { font-size: 1.05rem; margin: 1.25rem 0 .5rem; }
    .muted { color: #6b6b6b; font-weight: normal; }
    .badges { display: flex; flex-wrap: wrap; gap: .4rem; margin: .5rem 0; }
    .badge {
      display: inline-block; padding: .15rem .55rem; border-radius: 999px;
      font-size: .8rem; color: #fff; white-space: nowrap;
    }
    .sev-critical { background: #7b1fa2; }
    .sev-high { background: #c62828; }
    .sev-medium { background: #ef6c00; }
    .sev-low { background: #f9a825; color: #1b1b1b; }
    .sev-informational { background: #1565c0; }
    .badge-kev {
      background: #111; color: #fff; border: 1px solid #c62828; font-weight: 600;
    }
    .cards { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem; }
    .card {
      background: #fff; border: 1px solid #e0e0e0; border-radius: 8px;
      padding: .75rem 1.25rem; min-width: 8rem;
    }
    .card .num { font-size: 1.8rem; font-weight: 600; }
    .card.kev { border-color: #c62828; }
    .card.kev .num { color: #c62828; }
    .card.kev.zero { border-color: #e0e0e0; }
    .card.kev.zero .num { color: #1b1b1b; }
    .card.top25 { border-color: #ef6c00; }
    .card.top25 .num { color: #ef6c00; }
    .card.top25.zero { border-color: #e0e0e0; }
    .card.top25.zero .num { color: #1b1b1b; }
    .badge-owasp { background: #37474f; }
    ul.owasp-list { list-style: none; padding: 0; margin: .5rem 0 0; max-width: 34rem; }
    ul.owasp-list li {
      display: flex; align-items: center; gap: .5rem;
      padding: .3rem 0; border-top: 1px solid #f0f0f0;
    }
    ul.owasp-list li .count { margin-left: auto; font-weight: 600; font-variant-numeric: tabular-nums; }
    svg { background: #fff; border: 1px solid #e0e0e0; border-radius: 8px; padding: .5rem; }
    .chart-label { font-size: 13px; fill: #1b1b1b; }
    .chart-count { font-size: 13px; fill: #1b1b1b; font-weight: 600; }
    section.host {
      background: #fff; border: 1px solid #e0e0e0; border-radius: 8px;
      padding: .5rem 1rem 1rem; margin-bottom: 1rem;
    }
    ul.host-findings { list-style: none; padding: 0; margin: .5rem 0 0; }
    ul.host-findings li { padding: .35rem 0; border-top: 1px solid #f0f0f0; }
    ul.host-findings li.kev { border-left: 3px solid #c62828; padding-left: .5rem; }
    .evidence { margin: .2rem 0 0 .25rem; font-size: .85rem; color: #444; }
    .evidence code { background: #f3f3f3; padding: .05rem .3rem; border-radius: 4px; word-break: break-all; }
    .toolbar {
      display: flex; flex-wrap: wrap; gap: .6rem; align-items: center; margin: .25rem 0 .75rem;
    }
    .toolbar input[type="search"], .toolbar select {
      font: inherit; padding: .35rem .5rem; border: 1px solid #ccc; border-radius: 6px; background: #fff;
    }
    .toolbar input[type="search"] { min-width: 14rem; }
    .toolbar label { font-size: .9rem; display: inline-flex; align-items: center; gap: .3rem; }
    #visible-count { color: #6b6b6b; font-size: .85rem; margin-left: auto; }
    table.findings { border-collapse: collapse; width: 100%; background: #fff; font-size: .9rem; }
    table.findings th, table.findings td {
      text-align: left; padding: .45rem .6rem; border-bottom: 1px solid #ececec;
    }
    table.findings thead th { background: #f0f0f0; cursor: pointer; user-select: none; position: sticky; top: 0; }
    table.findings thead th::after { content: " \2195"; color: #9a9a9a; font-size: .8em; }
    table.findings tbody tr:hover { background: #f7f7ff; }
    table.findings tbody tr.kev { background: #fff5f5; }
    table.findings tbody tr.kev:hover { background: #ffecec; }
    td.num { text-align: right; font-variant-numeric: tabular-nums; }
    .risk-badge { min-width: 2.2rem; text-align: center; }
    .empty { padding: 2rem; text-align: center; color: #6b6b6b; }
  </style>
</head>
<body>
  <header>
    <h1>{{ tool_name }} vulnerability report</h1>
    <div class="muted">{{ tool_name }} {{ tool_version }} &middot; detection &amp; reporting only</div>
  </header>

  <h2>Summary</h2>
  <div class="cards">
    <div class="card"><div class="num">{{ summary.total }}</div><div class="muted">findings</div></div>
    <div class="card"><div class="num">{{ summary.host_count }}</div><div class="muted">hosts</div></div>
    <div class="card kev{{ '' if kev_count else ' zero' }}" title="CVEs in the CISA Known Exploited Vulnerabilities catalog">
      <div class="num">{{ kev_count }}</div><div class="muted">known-exploited</div>
    </div>
    <div class="card top25{{ '' if standards.cwe_top_25 else ' zero' }}" title="Findings citing a 2023 CWE Top 25 Most Dangerous Weakness">
      <div class="num">{{ standards.cwe_top_25 }}</div><div class="muted">CWE Top 25</div>
    </div>
  </div>
  <div class="badges">
    {% for severity in severity_order %}
    <span class="badge {{ styles[severity].css_class }}">{{ styles[severity].label }}: {{ summary.by_severity[severity] }}</span>
    {% endfor %}
  </div>

  <h2>Severity breakdown</h2>
  <svg width="{{ chart.width }}" height="{{ chart.height }}" role="img" aria-label="Findings by severity">
    {% for bar in chart.bars %}
    <text x="0" y="{{ bar.text_y }}" class="chart-label">{{ bar.label }}</text>
    <rect x="{{ chart.bar_x }}" y="{{ bar.rect_y }}" width="{{ bar.width }}" height="{{ bar.bar_height }}" rx="3" fill="{{ bar.color }}"></rect>
    <text x="{{ bar.count_x }}" y="{{ bar.text_y }}" class="chart-count">{{ bar.count }}</text>
    {% endfor %}
  </svg>

  <h2>OWASP Top 10 (2021)</h2>
  {% if standards.any_mapped %}
  <ul class="owasp-list">
    {% for category, count in standards.owasp.items() %}
    {% if count %}
    <li>
      <span class="badge badge-owasp">{{ category.short }}</span>
      <span>{{ category.title }}</span>
      <span class="count">{{ count }}</span>
    </li>
    {% endif %}
    {% endfor %}
  </ul>
  {% if standards.uncategorized %}
  <p class="muted">{{ standards.uncategorized }} finding{{ "s" if standards.uncategorized != 1 else "" }} not mapped to an OWASP Top 10 category.</p>
  {% endif %}
  {% else %}
  <p class="empty">No findings map to an OWASP Top 10 category.</p>
  {% endif %}

  <h2>Per-host breakdown</h2>
  {% if host_groups %}
    {% for group in host_groups %}
    <section class="host">
      <h3>{{ group.host }} <span class="muted">({{ group.findings | length }} finding{{ "s" if group.findings | length != 1 else "" }})</span></h3>
      <div class="badges">
        {% for severity in severity_order %}
        {% if group.counts[severity] %}
        <span class="badge {{ styles[severity].css_class }}">{{ styles[severity].label }}: {{ group.counts[severity] }}</span>
        {% endif %}
        {% endfor %}
      </div>
      <ul class="host-findings">
        {% for finding in group.findings %}
        <li{% if finding.kev %} class="kev"{% endif %}>
          <span class="badge {{ styles[finding.severity].css_class }}">{{ styles[finding.severity].label }}</span>
          <span class="badge risk-badge {{ risk_css(finding.risk_score) }}" title="Composite risk score (0-100)">{{ finding.risk_score }}</span>
          {% if finding.kev %}<span class="badge badge-kev" title="Actively exploited in the wild (CISA KEV)">&#9888; Known-exploited</span>{% endif %}
          <strong>{{ finding.title }}</strong>{% if finding.port is not none %} <span class="muted">:{{ finding.port }}</span>{% endif %}
          {% if finding.evidence %}<div class="evidence">Evidence: <code>{{ finding.evidence }}</code></div>{% endif %}
        </li>
        {% endfor %}
      </ul>
    </section>
    {% endfor %}
  {% else %}
    <p class="empty">No findings.</p>
  {% endif %}

  <h2>All findings</h2>
  <div class="toolbar">
    <input type="search" id="search" placeholder="Filter findings&hellip;" aria-label="Filter findings">
    <select id="severity-filter" aria-label="Filter by severity">
      <option value="">All severities</option>
      {% for severity in severity_order %}
      <option value="{{ severity.value }}">{{ styles[severity].label }}</option>
      {% endfor %}
    </select>
    <label><input type="checkbox" id="kev-only"> Known-exploited only</label>
    <span id="visible-count"></span>
  </div>
  <table class="findings" id="findings-table">
    <thead>
      <tr>
        <th data-type="number">Severity</th>
        <th data-type="number">Risk</th>
        <th data-type="text">Host</th>
        <th data-type="number">Port</th>
        <th data-type="text">Title</th>
        <th data-type="text">CVEs</th>
        <th data-type="text">OWASP</th>
        <th data-type="number">CVSS</th>
        <th data-type="number">EPSS</th>
        <th data-type="number">KEV</th>
        <th data-type="text">Confidence</th>
        <th data-type="text">Source</th>
      </tr>
    </thead>
    <tbody>
      {% for finding in findings %}
      <tr data-severity="{{ finding.severity.value }}" data-kev="{{ 1 if finding.kev else 0 }}">
        <td data-sort="{{ finding.severity.rank }}"><span class="badge {{ styles[finding.severity].css_class }}">{{ styles[finding.severity].label }}</span></td>
        <td class="num" data-sort="{{ finding.risk_score }}"><span class="badge risk-badge {{ risk_css(finding.risk_score) }}">{{ finding.risk_score }}</span></td>
        <td>{{ finding.host }}</td>
        <td class="num" data-sort="{{ finding.port if finding.port is not none else -1 }}">{{ finding.port if finding.port is not none else "" }}</td>
        <td>{{ finding.title }}</td>
        <td>{{ finding.cve_ids | join(", ") }}</td>
        <td>{{ finding_owasp(finding) | map(attribute="short") | join(", ") }}</td>
        <td class="num" data-sort="{{ finding.cvss_score if finding.cvss_score is not none else -1 }}">{{ "%.1f" | format(finding.cvss_score) if finding.cvss_score is not none else "" }}</td>
        <td class="num" data-sort="{{ finding.epss_score if finding.epss_score is not none else -1 }}">{{ "%.1f%%" | format(finding.epss_score * 100) if finding.epss_score is not none else "" }}</td>
        <td class="num" data-sort="{{ 1 if finding.kev else 0 }}">{% if finding.kev %}<span class="badge badge-kev" title="Actively exploited in the wild (CISA KEV)">&#9888;</span>{% endif %}</td>
        <td>{{ finding.confidence.value if finding.confidence is not none else "" }}</td>
        <td>{{ finding.source }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <script>
    (function () {
      var table = document.getElementById("findings-table");
      if (!table) { return; }

      // --- column sorting ------------------------------------------------- //
      var headers = table.tHead.rows[0].cells;
      for (var i = 0; i < headers.length; i++) {
        (function (column) {
          headers[column].addEventListener("click", function () {
            sortBy(column, headers[column].getAttribute("data-type") === "number");
          });
        })(i);
      }
      var ascending = [];
      function cellKey(row, column, numeric) {
        var cell = row.cells[column];
        var raw = cell.hasAttribute("data-sort") ? cell.getAttribute("data-sort") : cell.textContent;
        return numeric ? parseFloat(raw) : raw.toLowerCase();
      }
      function sortBy(column, numeric) {
        var body = table.tBodies[0];
        var rows = Array.prototype.slice.call(body.rows);
        var dir = ascending[column] = !ascending[column];
        rows.sort(function (a, b) {
          var ka = cellKey(a, column, numeric), kb = cellKey(b, column, numeric);
          if (ka < kb) { return dir ? -1 : 1; }
          if (ka > kb) { return dir ? 1 : -1; }
          return 0;
        });
        for (var i = 0; i < rows.length; i++) { body.appendChild(rows[i]); }
      }

      // --- filtering ------------------------------------------------------ //
      var search = document.getElementById("search");
      var severityFilter = document.getElementById("severity-filter");
      var kevOnly = document.getElementById("kev-only");
      var counter = document.getElementById("visible-count");
      var allRows = Array.prototype.slice.call(table.tBodies[0].rows);

      function applyFilters() {
        var q = search.value.toLowerCase();
        var sev = severityFilter.value;
        var kev = kevOnly.checked;
        var shown = 0;
        for (var i = 0; i < allRows.length; i++) {
          var row = allRows[i];
          var matchText = q === "" || row.textContent.toLowerCase().indexOf(q) !== -1;
          var matchSev = sev === "" || row.getAttribute("data-severity") === sev;
          var matchKev = !kev || row.getAttribute("data-kev") === "1";
          var visible = matchText && matchSev && matchKev;
          row.style.display = visible ? "" : "none";
          if (visible) { shown++; }
        }
        counter.textContent = "showing " + shown + " of " + allRows.length + " findings";
      }
      search.addEventListener("input", applyFilters);
      severityFilter.addEventListener("change", applyFilters);
      kevOnly.addEventListener("change", applyFilters);
      applyFilters();
    })();
  </script>
</body>
</html>
