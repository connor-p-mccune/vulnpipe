# Copy to .env (gitignored) and fill in. Secrets NEVER go in committed config.

# OWASP ZAP daemon API key (must match the ZAP service config).
ZAP_API_KEY=changeme

# OWASP ZAP daemon base URL. Leave unset for a local daemon (defaults to
# http://localhost:8080); the docker-compose stack sets this to http://zap:8080.
ZAP_API_URL=

# NVD API key for enrichment (optional but raises rate limits).
NVD_API_KEY=

# Credentials for authenticated ZAP scanning, referenced by name from the
# targets file (username_env / password_env).
APP_USERNAME=
APP_PASSWORD=

# Bearer/JWT token for header-based authenticated scanning (token_env).
API_BEARER_TOKEN=

# Slack-compatible incoming webhook URL for `vulnpipe notify` (a secret; carries a
# token). Referenced by name via --webhook-url-env (default VULNPIPE_WEBHOOK_URL).
VULNPIPE_WEBHOOK_URL=
