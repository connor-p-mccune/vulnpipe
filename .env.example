# Copy to .env (gitignored) and fill in. Secrets NEVER go in committed config.

# OWASP ZAP daemon API key (must match the ZAP service config).
ZAP_API_KEY=changeme

# NVD API key for enrichment (optional but raises rate limits).
NVD_API_KEY=

# Credentials for authenticated ZAP scanning, referenced by name from the
# targets file (username_env / password_env).
APP_USERNAME=
APP_PASSWORD=
